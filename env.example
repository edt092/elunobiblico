# Credenciales Payphone — copia este archivo como .env.local y rellena tus valores
NEXT_PUBLIC_PP_TOKEN=tu_token_payphone_aqui
NEXT_PUBLIC_PP_STORE_ID=tu_store_id_aqui

# Telegram — Bot para notificaciones de venta
# 1. Crea un bot con @BotFather en Telegram → te da el BOT_TOKEN
# 2. Escribe cualquier mensaje al bot y visita:
#    https://api.telegram.org/bot{TU_BOT_TOKEN}/getUpdates
#    El campo "chat.id" es tu CHAT_ID
TELEGRAM_BOT_TOKEN=tu_bot_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui
